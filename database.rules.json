{
  "rules": {
    "events": {
      "$eventId": {
        ".read": true,
        ".write": "auth != null",
        "turn_counter": {
          ".write": "root.child('events').child($eventId).child('status').val() === 'active'"
        }
      }
    },
    "queue": {
      "$eventId": {
        ".read": "auth != null",
        "$clientId": {
          ".write": "root.child('events').child($eventId).child('status').val() === 'active'"
        }
      }
    },
    "admin": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "logs": {
      "$eventId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    }
  }
}
